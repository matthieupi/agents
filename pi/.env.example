# Pi environment configuration
# Copy to .env and fill in values

# =============================================================================
# USER/GROUP IDS
# =============================================================================
UID=1000
GID=1000

# =============================================================================
# API PROVIDERS (set the ones you need)
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
XAI_API_KEY=
HF_TOKEN=
KIMI_API_KEY=
MINIMAX_API_KEY=

# =============================================================================
# LAN-HOSTED MODELS - OLLAMA
# =============================================================================
# Default works when the Pi container is attached to the same Docker network as
# the Ollama service.
# For a remote Ollama server, also update state/.pi/agent/models.json.
OLLAMA_HOST=http://ollama:11434

# =============================================================================
# WORKSPACE CONFIGURATION
# =============================================================================
WORKSPACE_PATH=./workspace

# =============================================================================
# GIT CONFIGURATION
# =============================================================================
GIT_AUTHOR_NAME=pi-xmist
GIT_AUTHOR_EMAIL=pi@xmist.dev

# =============================================================================
# SSH DIRECTORY FOR REMOTE ACCESS
# =============================================================================
SSH_DIR_PATH=./ssh

# =============================================================================
# PI RUNTIME OPTIONS
# =============================================================================
PI_SKIP_VERSION_CHECK=1

# =============================================================================
# OPTIONAL: CUSTOM GITCONFIG
# =============================================================================
# GITCONFIG_PATH=/home/youruser/.gitconfig
