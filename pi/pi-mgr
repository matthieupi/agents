#!/bin/bash
# Pi Container Manager
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGE_NAME="lab/pi:latest"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[pi-mgr]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[pi-mgr]${NC} $*"; }
log_error() { echo -e "${RED}[pi-mgr]${NC} $*" >&2; }

usage() {
    cat << EOF
Pi Container Manager

Usage: $(basename "$0") <command> [options]

Commands:
    list, ls              List all pi containers
    build, rebuild, update Rebuild image and refresh containers
    login [path]          Run Pi with OAuth callback ports open
    stop <name|all>       Stop container(s)
    start <name>          Start a stopped container
    remove, rm <name|all> Remove container(s)
    clean [-f]            Remove stopped containers (-f: stop all first)
    fclean                Force clean: stop all containers, then remove
    logs <name>           Show container logs
    shell <name>          Open bash shell in container
EOF
    exit 0
}

list_containers() {
    log_info "Pi containers:"
    docker ps -a --filter "name=pi-" \
        --format "table {{.Names}}\t{{.Status}}\t{{.Size}}" || true
}

stop_containers() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        log_error "Specify container name or 'all'"
        exit 1
    fi

    if [[ "$target" == "all" ]]; then
        log_info "Stopping all pi containers..."
        docker ps -q --filter "name=pi-" | xargs -r docker stop
    else
        log_info "Stopping container: $target"
        docker stop "$target"
    fi
}

start_container() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Specify container name"
        exit 1
    fi

    log_info "Starting container: $name"
    docker start "$name"
}

remove_containers() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        log_error "Specify container name or 'all'"
        exit 1
    fi

    if [[ "$target" == "all" ]]; then
        log_warn "Removing all pi containers..."
        read -p "Are you sure? (y/N) " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            docker ps -aq --filter "name=pi-" | xargs -r docker rm -f
        fi
    else
        log_info "Removing container: $target"
        docker rm -f "$target"
    fi
}

clean_containers() {
    local force="${1:-}"

    if [[ "$force" == "-f" ]]; then
        log_warn "Force clean: stopping all pi containers first..."
        docker ps -q --filter "name=pi-" | xargs -r docker stop
    fi

    log_info "Removing stopped pi containers..."
    docker ps -aq --filter "name=pi-" --filter "status=exited" | xargs -r docker rm
}

show_logs() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Specify container name"
        exit 1
    fi

    docker logs -f "$name"
}

open_shell() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Specify container name"
        exit 1
    fi

    docker exec -it "$name" /bin/bash
}

rebuild_image() {
    log_info "Rebuilding ${IMAGE_NAME} from local workspace..."
    docker build --pull -t "${IMAGE_NAME}" "${SCRIPT_DIR}"
    log_info "Image rebuilt successfully"

    local container_ids
    container_ids="$(docker ps -aq --filter "name=pi-")"
    if [[ -n "${container_ids}" ]]; then
        log_warn "Refreshing existing pi workspace containers..."
        docker rm -f ${container_ids} > /dev/null
        log_info "Containers removed. They will be recreated on next run."
    else
        log_info "No existing pi workspace containers to refresh."
    fi
}

login_pi() {
    shift || true
    exec "${SCRIPT_DIR}/pi-run" --login "$@"
}

CMD="${1:-}"
case "$CMD" in
    list|ls)
        list_containers
        ;;
    build|rebuild|update)
        rebuild_image
        ;;
    login)
        login_pi "$@"
        ;;
    stop)
        stop_containers "${2:-}"
        ;;
    start)
        start_container "${2:-}"
        ;;
    remove|rm)
        remove_containers "${2:-}"
        ;;
    clean)
        clean_containers "${2:-}"
        ;;
    fclean)
        clean_containers "-f"
        ;;
    logs)
        show_logs "${2:-}"
        ;;
    shell)
        open_shell "${2:-}"
        ;;
    help|--help|-h|"")
        usage
        ;;
    *)
        log_error "Unknown command: $CMD"
        usage
        ;;
esac
