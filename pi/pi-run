#!/bin/bash
# Pi Wrapper - Manages per-directory containerized instances
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

IMAGE_NAME="lab/pi:latest"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[pi]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[pi]${NC} $*"; }
log_error() { echo -e "${RED}[pi]${NC} $*" >&2; }

remove_container_if_exists() {
    local name="$1"
    if docker ps -aq --filter "name=^${name}$" | grep -q .; then
        docker rm -f "$name" > /dev/null 2>&1 || true
    fi
}

container_has_login_ports() {
    local name="$1"
    local ports
    ports="$(docker inspect --format '{{range $port, $bindings := .HostConfig.PortBindings}}{{printf "%s\n" $port}}{{end}}' "$name" 2>/dev/null || true)"
    grep -q '^1455/tcp$' <<<"$ports" && \
        grep -q '^8085/tcp$' <<<"$ports" && \
        grep -q '^51121/tcp$' <<<"$ports" && \
        grep -q '^53692/tcp$' <<<"$ports"
}

container_on_network() {
    local name="$1"
    local network="$2"
    docker inspect --format '{{range $key, $_ := .NetworkSettings.Networks}}{{printf "%s\n" $key}}{{end}}' "$name" 2>/dev/null | grep -qx "$network"
}

REBUILD_IMAGE=""
LOGIN_MODE=""
EXTENSION_PRESET=""
POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        -r|--rebuild)
            REBUILD_IMAGE="1"
            shift
            ;;
        --login)
            LOGIN_MODE="1"
            shift
            ;;
        --extension-preset)
            if [[ $# -lt 2 ]]; then
                log_error "--extension-preset requires a value"
                exit 1
            fi
            EXTENSION_PRESET="$2"
            shift 2
            ;;
        *)
            POSITIONAL_ARGS+=("$1")
            shift
            ;;
    esac
done

if [[ -n "${REBUILD_IMAGE}" ]]; then
    log_info "Rebuilding Pi image..."
    docker build -t "${IMAGE_NAME}" "${SCRIPT_DIR}"
    log_info "Image rebuilt successfully"
    exit 0
fi

set -- "${POSITIONAL_ARGS[@]+"${POSITIONAL_ARGS[@]}"}"

WORKSPACE_PATH="."
PI_ARGS=()

if [[ $# -gt 0 ]]; then
    if [[ -d "$1" ]]; then
        WORKSPACE_PATH="$(realpath "$1")"
        shift
    fi
fi

if [[ "$WORKSPACE_PATH" == "." ]]; then
    WORKSPACE_PATH="$(realpath ".")"
fi

if [[ ! -d "${WORKSPACE_PATH}" ]]; then
    log_error "Directory does not exist: ${WORKSPACE_PATH}"
    exit 1
fi

while [[ $# -gt 0 ]]; do
    PI_ARGS+=("$1")
    shift
done

CONTAINER_NAME="pi-$(basename "${WORKSPACE_PATH}")"
STATE_DIR="${SCRIPT_DIR}/.pi"
SSH_DIR="${SSH_DIR_PATH:-${SCRIPT_DIR}/ssh}"
GITCONFIG_PATH="${GITCONFIG_PATH:-/dev/null}"
AGENTS_DIR="${SCRIPT_DIR}/.."
INIT_SCRIPT="${SCRIPT_DIR}/init.sh"
DEFAULT_EXTENSION_ARGS=()
PRESET_EXTENSION_PATH=""

build_default_extension_args() {
    local host_dir="${STATE_DIR}/agent/extensions"
    local -a files=()
    local file

    if [[ ! -d "${host_dir}" ]]; then
        log_error "Extension preset requested, but the default extensions directory is missing: ${host_dir}"
        exit 1
    fi

    while IFS= read -r file; do
        files+=("${file}")
    done < <(find "${host_dir}" -maxdepth 1 -type f -name '*.ts' ! -name 'themeMap.ts' -printf '%f\n' | sort)

    if [[ ${#files[@]} -eq 0 ]]; then
        log_error "Extension preset requested, but no explicit default extensions were found in ${host_dir}"
        exit 1
    fi

    DEFAULT_EXTENSION_ARGS=()
    for file in "${files[@]}"; do
        DEFAULT_EXTENSION_ARGS+=("-e" "/home/pi/.pi/agent/extensions/${file}")
    done
}

resolve_preset_extension() {
    local preset_file=""
    local host_path=""

    case "${EXTENSION_PRESET}" in
        agent-team|agent-teams)
            preset_file="agent-team.ts"
            ;;
        agent-chain)
            preset_file="agent-chain.ts"
            ;;
        pi-pi)
            preset_file="pi-pi.ts"
            ;;
        *)
            log_error "Unknown extension preset: ${EXTENSION_PRESET}"
            exit 1
            ;;
    esac

    host_path="${STATE_DIR}/agent/extension-library/pi-vs-claude-code/${preset_file}"
    if [[ ! -f "${host_path}" ]]; then
        log_error "Extension preset file not found: ${host_path}"
        exit 1
    fi

    PRESET_EXTENSION_PATH="/home/pi/.pi/agent/extension-library/pi-vs-claude-code/${preset_file}"
}

mkdir -p "${STATE_DIR}/agent/sessions"

if [[ -n "${EXTENSION_PRESET}" ]]; then
    build_default_extension_args
    resolve_preset_extension
    PI_ARGS=(--no-extensions -e "${PRESET_EXTENSION_PATH}" "${DEFAULT_EXTENSION_ARGS[@]}" "${PI_ARGS[@]}")
fi

CONTAINER_STATUS=$(docker ps -a --filter "name=^${CONTAINER_NAME}$" --format "{{.Status}}" 2>/dev/null || echo "")

if [[ -n "${CONTAINER_STATUS}" ]]; then
    RUNNING=$(docker ps -q --filter "name=^${CONTAINER_NAME}$" --filter "status=running" 2>/dev/null || echo "")
    if [[ -n "${RUNNING}" ]]; then
        CONTAINER_IMAGE=$(docker inspect --format '{{.Config.Image}}' "${CONTAINER_NAME}" 2>/dev/null || echo "")
        if [[ "${CONTAINER_IMAGE}" == "${IMAGE_NAME}" ]]; then
            if ! container_on_network "${CONTAINER_NAME}" "proxy_net"; then
                log_warn "Container is missing proxy_net attachment, recreating..."
                remove_container_if_exists "${CONTAINER_NAME}"
            elif [[ -n "${LOGIN_MODE}" ]] && ! container_has_login_ports "${CONTAINER_NAME}"; then
                log_warn "Container is missing OAuth callback ports, recreating..."
                remove_container_if_exists "${CONTAINER_NAME}"
            else
                log_info "Attaching to existing session: ${CONTAINER_NAME}"
                log_info "Workspace: ${WORKSPACE_PATH}"
                if [[ -n "${EXTENSION_PRESET}" ]]; then
                    log_info "Extension preset: ${EXTENSION_PRESET}"
                fi
                exec docker exec -it "${CONTAINER_NAME}" pi "${PI_ARGS[@]}"
            fi
        else
            log_warn "Container uses old image (${CONTAINER_IMAGE}), recreating..."
            remove_container_if_exists "${CONTAINER_NAME}"
        fi
    else
        log_warn "Removing stale container: ${CONTAINER_NAME} (${CONTAINER_STATUS})"
        remove_container_if_exists "${CONTAINER_NAME}"
    fi
fi

log_info "Creating new Pi instance"
log_info "Workspace: ${WORKSPACE_PATH}"
log_info "Container: ${CONTAINER_NAME}"
if [[ -n "${EXTENSION_PRESET}" ]]; then
    log_info "Extension preset: ${EXTENSION_PRESET}"
fi

if ! docker image inspect "${IMAGE_NAME}" > /dev/null 2>&1; then
    log_error "Image ${IMAGE_NAME} not found. Build it first:"
    log_error "  cd ${SCRIPT_DIR} && docker compose build"
    log_error "  or: pi -r"
    exit 1
fi

log_info "Running Pi with UID $(id -u):$(id -g)"

docker_run_pi() {
    docker run -d \
        --name "${CONTAINER_NAME}" \
        --hostname "${CONTAINER_NAME}" \
        --restart unless-stopped \
        --user "1000:1000" \
        -e "HOME=/home/pi" \
        -e "PATH=/home/pi/.local/bin:/usr/local/bin:/usr/bin:/bin" \
        -e "TERM=xterm-256color" \
        -e "PI_CODING_AGENT_DIR=/home/pi/.pi/agent" \
        -e "PI_SKIP_VERSION_CHECK=${PI_SKIP_VERSION_CHECK:-1}" \
        -e "OLLAMA_HOST=${OLLAMA_HOST:-http://ollama:11434}" \
        -e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}" \
        -e "OPENAI_API_KEY=${OPENAI_API_KEY:-}" \
        -e "GEMINI_API_KEY=${GEMINI_API_KEY:-}" \
        -e "OPENROUTER_API_KEY=${OPENROUTER_API_KEY:-}" \
        -e "MISTRAL_API_KEY=${MISTRAL_API_KEY:-}" \
        -e "GROQ_API_KEY=${GROQ_API_KEY:-}" \
        -e "CEREBRAS_API_KEY=${CEREBRAS_API_KEY:-}" \
        -e "XAI_API_KEY=${XAI_API_KEY:-}" \
        -e "HF_TOKEN=${HF_TOKEN:-}" \
        -e "KIMI_API_KEY=${KIMI_API_KEY:-}" \
        -e "MINIMAX_API_KEY=${MINIMAX_API_KEY:-}" \
        -e "GIT_AUTHOR_NAME=${GIT_AUTHOR_NAME:-pi-xmist}" \
        -e "GIT_AUTHOR_EMAIL=${GIT_AUTHOR_EMAIL:-pi@xmist.dev}" \
        -e "GIT_COMMITTER_NAME=${GIT_AUTHOR_NAME:-pi-xmist}" \
        -e "GIT_COMMITTER_EMAIL=${GIT_AUTHOR_EMAIL:-pi@xmist.dev}" \
        -v "${WORKSPACE_PATH}:/workspace:rw" \
        -v "${AGENTS_DIR}:/opt/agents:rw" \
        -v "${INIT_SCRIPT}:/opt/harness/init.sh:ro" \
        -v "${STATE_DIR}:/home/pi/.pi:rw" \
        -v "${SSH_DIR}:/home/pi/.ssh:ro" \
        -v "${GITCONFIG_PATH}:/home/pi/.gitconfig:ro" \
        --add-host host.docker.internal:host-gateway \
        "$@" \
        --network devai-xmist \
        --memory 12g \
        --cpus 2.0 \
        "${IMAGE_NAME}" \
        bash -lc '/opt/harness/init.sh && tail -f /dev/null'
}

LOGIN_PORT_ARGS=(
    -p 127.0.0.1:1455:1455
    -p 127.0.0.1:8085:8085
    -p 127.0.0.1:51121:51121
    -p 127.0.0.1:53692:53692
)

RUN_LOG="$(mktemp)"
if [[ -n "${LOGIN_MODE}" ]]; then
    if ! docker_run_pi "${LOGIN_PORT_ARGS[@]}" > /dev/null 2>"${RUN_LOG}"; then
        remove_container_if_exists "${CONTAINER_NAME}"
        if grep -Eq "address already in use|port is already allocated|Bind for 127\.0\.0\.1:(1455|8085|51121|53692) failed" "${RUN_LOG}"; then
            log_error "OAuth callback ports are already in use."
            log_error "Stop the other Pi login container holding localhost callback ports, then retry 'pi login'."
        else
            cat "${RUN_LOG}" >&2
        fi
        rm -f "${RUN_LOG}"
        exit 1
    fi
else
    if ! docker_run_pi > /dev/null 2>"${RUN_LOG}"; then
        remove_container_if_exists "${CONTAINER_NAME}"
        cat "${RUN_LOG}" >&2
        rm -f "${RUN_LOG}"
        exit 1
    fi
fi
rm -f "${RUN_LOG}"

docker network connect proxy_net "${CONTAINER_NAME}" > /dev/null 2>&1 || true

log_info "Container created successfully"

sleep 2

if ! docker ps -q --filter "name=^${CONTAINER_NAME}$" --filter "status=running" | grep -q .; then
    log_error "Container failed to start. Check logs:"
    log_error "  docker logs ${CONTAINER_NAME}"
    exit 1
fi

log_info "Attaching to Pi..."
exec docker exec -it "${CONTAINER_NAME}" pi "${PI_ARGS[@]}"
