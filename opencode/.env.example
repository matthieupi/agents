# OpenCode Environment Configuration
# Copy to .env and fill in values

# =============================================================================
# USER/GROUP IDS
# =============================================================================
UID=1000
GID=1000

# =============================================================================
# CLOUD API PROVIDERS (set the ones you need)
# =============================================================================
# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API
OPENAI_API_KEY=sk-xxxxx

# Google Gemini API
GEMINI_API_KEY=

# OpenRouter API
OPENROUTER_API_KEY=

# =============================================================================
# LAN-HOSTED MODELS - OLLAMA
# =============================================================================
# Ollama server URL on your LAN
OLLAMA_HOST=http://ollama.xmist.dev:11434

# =============================================================================
# OPENAI-COMPATIBLE ENDPOINTS (vLLM, LocalAI, LM Studio, etc.)
# =============================================================================
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=

# =============================================================================
# WORKSPACE CONFIGURATION
# =============================================================================
# Path to your project directory (mounted as /workspace in container)
WORKSPACE_PATH=./workspace

# =============================================================================
# GIT CONFIGURATION (for commits made by opencode)
# =============================================================================
GIT_AUTHOR_NAME=opencode-xmist
GIT_AUTHOR_EMAIL=opencode@xmist.dev

# =============================================================================
# SSH DIRECTORY FOR REMOTE ACCESS
# =============================================================================
# Path to SSH directory containing keys, config, and known_hosts
SSH_DIR_PATH=./ssh

# =============================================================================
# OPTIONAL: CUSTOM GITCONFIG
# =============================================================================
# GITCONFIG_PATH=/home/youruser/.gitconfig
