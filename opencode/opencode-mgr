#!/bin/bash
# OpenCode Container Manager
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
IMAGE_NAME="lab/opencode:latest"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[opencode-mgr]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[opencode-mgr]${NC} $*"; }
log_error() { echo -e "${RED}[opencode-mgr]${NC} $*" >&2; }

# Show usage
usage() {
    cat << EOF
OpenCode Container Manager

Usage: $(basename "$0") <command> [options]

Commands:
    list, ls              List all opencode containers
    rebuild, update       Rebuild image and refresh containers
    stop <name|all>       Stop container(s)
    start <name>          Start a stopped container
    remove, rm <name|all> Remove container(s)
    clean [-f]            Remove stopped containers (-f: stop all first)
    fclean                Force clean: stop all containers, then remove
    logs <name>           Show container logs
    shell <name>          Open bash shell in container

Examples:
    $(basename "$0") list
    $(basename "$0") rebuild
    $(basename "$0") stop opencode-myproject
    $(basename "$0") stop all
    $(basename "$0") clean
EOF
    exit 0
}

# List all opencode containers
list_containers() {
    log_info "OpenCode containers:"
    docker ps -a --filter "name=opencode-" \
        --format "table {{.Names}}\t{{.Status}}\t{{.Size}}" || true
}

# Stop containers
stop_containers() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        log_error "Specify container name or 'all'"
        exit 1
    fi

    if [[ "$target" == "all" ]]; then
        log_info "Stopping all opencode containers..."
        docker ps -q --filter "name=opencode-" | xargs -r docker stop
    else
        log_info "Stopping container: $target"
        docker stop "$target"
    fi
}

# Start container
start_container() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Specify container name"
        exit 1
    fi

    log_info "Starting container: $name"
    docker start "$name"
}

# Remove containers
remove_containers() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        log_error "Specify container name or 'all'"
        exit 1
    fi

    if [[ "$target" == "all" ]]; then
        log_warn "Removing all opencode containers..."
        read -p "Are you sure? (y/N) " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            docker ps -aq --filter "name=opencode-" | xargs -r docker rm -f
        fi
    else
        log_info "Removing container: $target"
        docker rm -f "$target"
    fi
}

# Clean stopped containers
clean_containers() {
    local force="${1:-}"

    if [[ "$force" == "-f" ]]; then
        log_warn "Force clean: stopping all opencode containers first..."
        docker ps -q --filter "name=opencode-" | xargs -r docker stop
    fi

    log_info "Removing stopped opencode containers..."
    docker ps -aq --filter "name=opencode-" --filter "status=exited" | xargs -r docker rm
}

# Show logs
show_logs() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Specify container name"
        exit 1
    fi

    docker logs -f "$name"
}

# Open shell
open_shell() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Specify container name"
        exit 1
    fi

    docker exec -it "$name" /bin/bash
}

rebuild_image() {
    log_info "Rebuilding ${IMAGE_NAME} from local workspace..."
    docker build --pull -t "${IMAGE_NAME}" "${SCRIPT_DIR}"
    log_info "Image rebuilt successfully"

    local container_ids
    container_ids="$(docker ps -aq --filter "name=opencode-")"
    if [[ -n "${container_ids}" ]]; then
        log_warn "Refreshing existing opencode workspace containers..."
        docker rm -f ${container_ids} > /dev/null
        log_info "Containers removed. They will be recreated on next run."
    else
        log_info "No existing opencode workspace containers to refresh."
    fi
}

# Main command router
CMD="${1:-}"
case "$CMD" in
    list|ls)
        list_containers
        ;;
    rebuild|update)
        rebuild_image
        ;;
    stop)
        stop_containers "${2:-}"
        ;;
    start)
        start_container "${2:-}"
        ;;
    remove|rm)
        remove_containers "${2:-}"
        ;;
    clean)
        clean_containers "${2:-}"
        ;;
    fclean)
        clean_containers "-f"
        ;;
    logs)
        show_logs "${2:-}"
        ;;
    shell)
        open_shell "${2:-}"
        ;;
    help|--help|-h|"")
        usage
        ;;
    *)
        log_error "Unknown command: $CMD"
        usage
        ;;
esac
