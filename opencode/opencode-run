#!/bin/bash
# OpenCode Wrapper - Manages per-directory containerized instances
set -euo pipefail

# Follow symlinks to find the real script directory
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

COMPOSE_FILE="${SCRIPT_DIR}/docker-compose.yml"
IMAGE_NAME="lab/opencode:latest"

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() { echo -e "${GREEN}[opencode]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[opencode]${NC} $*"; }
log_error() { echo -e "${RED}[opencode]${NC} $*" >&2; }

# Parse optional flags
DANGEROUS_MODE=""
REBUILD_IMAGE=""
POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        -d|--dangerous)
            DANGEROUS_MODE="--permission allow"
            log_warn "Running in DANGEROUS MODE - all permissions auto-approved!"
            shift
            ;;
        -r|--rebuild)
            REBUILD_IMAGE="1"
            shift
            ;;
        *)
            POSITIONAL_ARGS+=("$1")
            shift
            ;;
    esac
done

# Handle rebuild if requested
if [[ -n "${REBUILD_IMAGE}" ]]; then
    log_info "Rebuilding OpenCode image..."
    docker build -t "${IMAGE_NAME}" "${SCRIPT_DIR}"
    log_info "Image rebuilt successfully"
    exit 0
fi

# Restore positional parameters
set -- "${POSITIONAL_ARGS[@]+"${POSITIONAL_ARGS[@]}"}"

# Parse workspace path
WORKSPACE_PATH="${1:-.}"
WORKSPACE_PATH="$(realpath "${WORKSPACE_PATH}")"

# Validate workspace exists
if [[ ! -d "${WORKSPACE_PATH}" ]]; then
    log_error "Directory does not exist: ${WORKSPACE_PATH}"
    exit 1
fi

# Generate unique container name based on workspace path
CONTAINER_NAME="opencode-$(basename "${WORKSPACE_PATH}")"

# Check if container exists and is running
CONTAINER_STATUS=$(docker ps -a --filter "name=^${CONTAINER_NAME}$" --format "{{.Status}}" 2>/dev/null || echo "")

if [[ -n "${CONTAINER_STATUS}" ]]; then
    # Container exists - check if it's healthy and running
    RUNNING=$(docker ps -q --filter "name=^${CONTAINER_NAME}$" --filter "status=running" 2>/dev/null || echo "")
    if [[ -n "${RUNNING}" ]]; then
        # Verify it's using the current image
        CONTAINER_IMAGE=$(docker inspect --format '{{.Config.Image}}' "${CONTAINER_NAME}" 2>/dev/null || echo "")
        if [[ "${CONTAINER_IMAGE}" == "${IMAGE_NAME}" ]]; then
            log_info "Attaching to existing session: ${CONTAINER_NAME}"
            log_info "Workspace: ${WORKSPACE_PATH}"
            exec docker exec -it "${CONTAINER_NAME}" opencode ${DANGEROUS_MODE}
        else
            log_warn "Container uses old image (${CONTAINER_IMAGE}), recreating..."
            docker rm -f "${CONTAINER_NAME}" > /dev/null 2>&1
        fi
    else
        # Container exists but is stopped/restarting/dead - remove and recreate
        log_warn "Removing stale container: ${CONTAINER_NAME} (${CONTAINER_STATUS})"
        docker rm -f "${CONTAINER_NAME}" > /dev/null 2>&1
    fi
fi

# Container doesn't exist - create new one
log_info "Creating new OpenCode instance"
log_info "Workspace: ${WORKSPACE_PATH}"
log_info "Container: ${CONTAINER_NAME}"

# Check if image exists
if ! docker image inspect "${IMAGE_NAME}" > /dev/null 2>&1; then
    log_error "Image ${IMAGE_NAME} not found. Build it first:"
    log_error "  cd ${SCRIPT_DIR} && docker compose build"
    log_error "  or: opencode -r ."
    exit 1
fi

# Prepare config directory
CONFIG_DIR="${SCRIPT_DIR}/.opencode/config"
mkdir -p "${CONFIG_DIR}"

# Prepare data directory for session/auth persistence
DATA_DIR="${SCRIPT_DIR}/.opencode/data"
mkdir -p "${DATA_DIR}"

# Prepare cache directory for provider/plugin state persistence
CACHE_DIR="${SCRIPT_DIR}/.opencode/cache"
mkdir -p "${CACHE_DIR}"
AGENT_DIR="${SCRIPT_DIR}/../agent"
INIT_SCRIPT="${SCRIPT_DIR}/init.sh"

# SSH directory for remote access
SSH_DIR="${SSH_DIR_PATH:-${SCRIPT_DIR}/ssh}"

log_info "Running OpenCode with UID $(id -u):$(id -g)"

# Create container with workspace-specific settings
docker run -d \
    --name "${CONTAINER_NAME}" \
    --hostname "${CONTAINER_NAME}" \
    --restart unless-stopped \
    --user "1000:1000" \
    -e "HOME=/home/opencode" \
    -e "PATH=/home/opencode/.local/bin:/usr/local/bin:/usr/bin:/bin" \
    -e "OPENCODE_CONFIG_DIR=/home/opencode/.config/opencode" \
    -e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}" \
    -e "OPENAI_API_KEY=${OPENAI_API_KEY:-}" \
    -e "GEMINI_API_KEY=${GEMINI_API_KEY:-}" \
    -e "OPENROUTER_API_KEY=${OPENROUTER_API_KEY:-}" \
    -e "OLLAMA_HOST=${OLLAMA_HOST:-http://ollama.xmist.dev:11434}" \
    -e "OPENAI_COMPAT_API_KEY=${OPENAI_COMPAT_API_KEY:-}" \
    -e "OPENAI_COMPAT_BASE_URL=${OPENAI_COMPAT_BASE_URL:-}" \
    -e "OPENCODE_CONFIG=/home/opencode/.config/opencode/opencode.json" \
    -e "OPENCODE_DISABLE_AUTOUPDATE=1" \
    -e "TERM=xterm-256color" \
    -e "GIT_AUTHOR_NAME=${GIT_AUTHOR_NAME:-opencode-xmist}" \
    -e "GIT_AUTHOR_EMAIL=${GIT_AUTHOR_EMAIL:-opencode@xmist.dev}" \
    -e "GIT_COMMITTER_NAME=${GIT_AUTHOR_NAME:-opencode-xmist}" \
    -e "GIT_COMMITTER_EMAIL=${GIT_AUTHOR_EMAIL:-opencode@xmist.dev}" \
    -v "${WORKSPACE_PATH}:/workspace:rw" \
    -v "${AGENT_DIR}:/opt/agent:rw" \
    -v "${INIT_SCRIPT}:/opt/harness/init.sh:ro" \
    -v "${CONFIG_DIR}:/home/opencode/.config/opencode:rw" \
    -v "${DATA_DIR}:/home/opencode/.local/share/opencode:rw" \
    -v "${CACHE_DIR}:/home/opencode/.cache/opencode:rw" \
    -v "${SSH_DIR}:/home/opencode/.ssh:ro" \
    --network devai-xmist \
    --memory 12g \
    --cpus 2.0 \
    "${IMAGE_NAME}" \
    bash -lc '/opt/harness/init.sh && tail -f /dev/null' > /dev/null

log_info "Container created successfully"

# Wait for container to be fully running
sleep 2

# Verify container is running before attaching
if ! docker ps -q --filter "name=^${CONTAINER_NAME}$" --filter "status=running" | grep -q .; then
    log_error "Container failed to start. Check logs:"
    log_error "  docker logs ${CONTAINER_NAME}"
    exit 1
fi

# Attach to the new container
log_info "Attaching to TUI..."
exec docker exec -it "${CONTAINER_NAME}" opencode ${DANGEROUS_MODE}
