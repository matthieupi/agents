# Claude Code Environment Configuration
# Copy to .env and fill in values

# =============================================================================
# ANTHROPIC API (required)
# =============================================================================
ANTHROPIC_API_KEY=

# =============================================================================
# USER/GROUP IDS
# =============================================================================
UID=1000
GID=1000

# =============================================================================
# GIT CONFIGURATION (for commits made by Claude)
# =============================================================================
GIT_AUTHOR_NAME=claude-xmist
GIT_AUTHOR_EMAIL=claude@xmist.dev

# =============================================================================
# WORKSPACE CONFIGURATION
# =============================================================================
# Path to your project directory (mounted as /workspace in container)
WORKSPACE_PATH=./workspace

# =============================================================================
# SSH DIRECTORY FOR REMOTE ACCESS
# =============================================================================
# Path to SSH directory containing keys, config, and known_hosts
# Default: ./ssh (contains agent-specific keys)
SSH_DIR_PATH=./ssh

# =============================================================================
# OPTIONAL: CUSTOM GITCONFIG
# =============================================================================
# GITCONFIG_PATH=/home/youruser/.gitconfig

# =============================================================================
# OPTIONAL: DISABLE TELEMETRY
# =============================================================================
CLAUDE_CODE_DISABLE_TELEMETRY=1
