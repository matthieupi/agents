#!/bin/bash
# Claude Code Wrapper - Manages per-directory containerized instances
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="${SCRIPT_DIR}/docker-compose.yml"
IMAGE_NAME="lab/claudecode:latest"

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() { echo -e "${GREEN}[claude]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[claude]${NC} $*"; }
log_error() { echo -e "${RED}[claude]${NC} $*" >&2; }

# Parse optional flags
DANGEROUS_MODE=""
REBUILD_IMAGE=""
POSITIONAL_ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        -d|--dangerous)
            DANGEROUS_MODE="--dangerously-skip-permissions"
            log_warn "Running in DANGEROUS MODE - permissions will be skipped!"
            shift
            ;;
        -r|--rebuild)
            REBUILD_IMAGE="1"
            shift
            ;;
        *)
            POSITIONAL_ARGS+=("$1")
            shift
            ;;
    esac
done

# Handle rebuild if requested
if [[ -n "${REBUILD_IMAGE}" ]]; then
    log_info "Rebuilding Claude Code image..."
    docker build -t "${IMAGE_NAME}" "${SCRIPT_DIR}"
    log_info "Image rebuilt successfully"
    exit 0
fi

# Restore positional parameters
set -- "${POSITIONAL_ARGS[@]}"

# Parse workspace path
WORKSPACE_PATH="${1:-.}"
WORKSPACE_PATH="$(realpath "${WORKSPACE_PATH}")"

# Validate workspace exists
if [[ ! -d "${WORKSPACE_PATH}" ]]; then
    log_error "Directory does not exist: ${WORKSPACE_PATH}"
    exit 1
fi

# Generate unique container name based on workspace path
# Convert path to safe container name: /coding/myproject -> claude-code-coding-myproject
CONTAINER_NAME="claude-$(echo "${WORKSPACE_PATH}" | sed 's|^/||; s|/|-|g')"
CONTAINER_NAME="claude-$(basename "${WORKSPACE_PATH}")"


# Check if container exists and is running
CONTAINER_STATUS=$(docker ps -a --filter "name=^${CONTAINER_NAME}$" --format "{{.Status}}" 2>/dev/null || echo "")

if [[ -n "${CONTAINER_STATUS}" ]]; then
  echo $CONTAINER_NAME
  echo $CONTAINER_STATUS
    # Container exists - check if it's running
    if docker ps -q --filter "name=^${CONTAINER_NAME}$" > /dev/null 2>&1; then
        log_info "Attaching to existing session: ${CONTAINER_NAME}"
        log_info "Workspace: ${WORKSPACE_PATH}"
        exec docker exec -it "${CONTAINER_NAME}" claude ${DANGEROUS_MODE} "${@:2}"
    else
        # Container exists but is stopped
        log_info "Starting stopped container: ${CONTAINER_NAME}"
        docker start "${CONTAINER_NAME}" > /dev/null
        sleep 1
        exec docker exec -it "${CONTAINER_NAME}" claude ${DANGEROUS_MODE} "${@:2}"
    fi
fi

# Container doesn't exist - create new one
log_info "Creating new Claude Code instance"
log_info "Workspace: ${WORKSPACE_PATH}"
log_info "Container: ${CONTAINER_NAME}"

# Check if image exists
if ! docker image inspect "${IMAGE_NAME}" > /dev/null 2>&1; then
    log_error "Image ${IMAGE_NAME} not found. Build it first:"
    log_error "  cd ${SCRIPT_DIR} && docker-compose build"
    exit 1
fi

# Enable if you want to use api_key instead of account login
# Check for ANTHROPIC_API_KEY
# if [[ -z "${ANTHROPIC_API_KEY:-}" ]]; then
#     log_error "ANTHROPIC_API_KEY environment variable not set"
#     log_error "Export it in your shell profile or .env file"
#     exit 1
# fi

# Prepare config directories for this workspace
CLAUDE_CONFIG_DIR="${SCRIPT_DIR}/.claude"
mkdir -p "${CLAUDE_CONFIG_DIR}"
AGENTS_DIR="${SCRIPT_DIR}/.."
INIT_SCRIPT="${SCRIPT_DIR}/init.sh"

# SSH directory for remote access
SSH_DIR="${SSH_DIR_PATH:-${SCRIPT_DIR}/ssh}"

log_info "Running Claude with UID $(id -u):$(id -g)"

# Create container with workspace-specific settings
    # Removed out for sudo access - uncomment to re-enable security hardening
    # --security-opt no-new-privileges:true \
    # --cap-drop ALL \
docker run -d \
    --name "${CONTAINER_NAME}" \
    --hostname "${CONTAINER_NAME}" \
    --restart unless-stopped \
    --user "1000:1000" \
    -e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}" \
    -e "CLAUDE_CONFIG_DIR=/home/claude/.claude" \
    -e "TERM=xterm-256color" \
    -e "GIT_AUTHOR_NAME=${GIT_AUTHOR_NAME:-claude-xmist}" \
    -e "GIT_AUTHOR_EMAIL=${GIT_AUTHOR_EMAIL:-claude@xmist.dev}" \
    -e "GIT_COMMITTER_NAME=${GIT_AUTHOR_NAME:-claude-xmist}" \
    -e "GIT_COMMITTER_EMAIL=${GIT_AUTHOR_EMAIL:-claude@xmist.dev}" \
    -e "CLAUDE_CODE_DISABLE_TELEMETRY=${CLAUDE_CODE_DISABLE_TELEMETRY:-1}" \
    -v "${WORKSPACE_PATH}:/workspace:rw" \
    -v "${AGENTS_DIR}:/opt/agents:rw" \
    -v "${INIT_SCRIPT}:/opt/harness/init.sh:ro" \
    -v "${CLAUDE_CONFIG_DIR}:/home/claude/.claude:rw" \
    -v "${SSH_DIR}:/home/claude/.ssh:ro" \
    --network devai-xmist \
    --memory 12g \
    --cpus 2.0 \
    "${IMAGE_NAME}" \
    bash -lc '/opt/harness/init.sh && tail -f /dev/null' > /dev/null

log_info "Container created successfully"
sleep 1

# Attach to the new container
exec docker exec -it "${CONTAINER_NAME}" claude ${DANGEROUS_MODE} "${@:2}"
