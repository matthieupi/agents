#!/bin/bash
# Claude Code Container Manager
set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[claude-mgr]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[claude-mgr]${NC} $*"; }
log_error() { echo -e "${RED}[claude-mgr]${NC} $*" >&2; }

# Show usage
usage() {
    cat << EOF
Claude Code Container Manager

Usage: $(basename "$0") <command> [options]

Commands:
    list, ls              List all claude-code containers
    stop <name|all>       Stop container(s)
    start <name>          Start a stopped container
    remove, rm <name|all> Remove container(s)
    clean [-f]            Remove stopped containers (-f: stop all first)
    fclean                Force clean: stop all containers, then remove
    logs <name>           Show container logs
    shell <name>          Open bash shell in container

Examples:
    $(basename "$0") list
    $(basename "$0") stop claude-code-coding-myproject
    $(basename "$0") stop all
    $(basename "$0") clean
EOF
    exit 0
}

# List all claude-code containers
list_containers() {
    log_info "Claude Code containers:"
    docker ps -a --filter "name=claude-" \
        --format "table {{.Names}}\t{{.Status}}\t{{.Size}}" || true
}

# Stop containers
stop_containers() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        log_error "Specify container name or 'all'"
        exit 1
    fi
    
    if [[ "$target" == "all" ]]; then
        log_info "Stopping all claude-code containers..."
        docker ps -q --filter "name=claude-" | xargs -r docker stop
    else
        log_info "Stopping container: $target"
        docker stop "$target"
    fi
}

# Start container
start_container() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Specify container name"
        exit 1
    fi
    
    log_info "Starting container: $name"
    docker start "$name"
}

# Remove containers
remove_containers() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        log_error "Specify container name or 'all'"
        exit 1
    fi
    
    if [[ "$target" == "all" ]]; then
        log_warn "Removing all claude-code containers..."
        read -p "Are you sure? (y/N) " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            docker ps -aq --filter "name=claude-" | xargs -r docker rm -f
        fi
    else
        log_info "Removing container: $target"
        docker rm -f "$target"
    fi
}

# Clean stopped containers
clean_containers() {
    local force="${1:-}"

    if [[ "$force" == "-f" ]]; then
        log_warn "Force clean: stopping all claude containers first..."
        docker ps -q --filter "name=claude-" | xargs -r docker stop
    fi

    log_info "Removing stopped claude-code containers..."
    docker ps -aq --filter "name=claude-" --filter "status=exited" | xargs -r docker rm
}

# Show logs
show_logs() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Specify container name"
        exit 1
    fi
    
    docker logs -f "$name"
}

# Open shell
open_shell() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        log_error "Specify container name"
        exit 1
    fi
    
    docker exec -it "$name" /bin/bash
}

# Main command router
CMD="${1:-}"
case "$CMD" in
    list|ls)
        list_containers
        ;;
    stop)
        stop_containers "${2:-}"
        ;;
    start)
        start_container "${2:-}"
        ;;
    remove|rm)
        remove_containers "${2:-}"
        ;;
    clean)
        clean_containers "${2:-}"
        ;;
    fclean)
        clean_containers "-f"
        ;;
    logs)
        show_logs "${2:-}"
        ;;
    shell)
        open_shell "${2:-}"
        ;;
    help|--help|-h|"")
        usage
        ;;
    *)
        log_error "Unknown command: $CMD"
        usage
        ;;
esac
